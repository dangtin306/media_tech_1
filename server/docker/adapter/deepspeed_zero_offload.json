{
  "train_micro_batch_size_per_gpu": 2,
  "gradient_accumulation_steps": 1,
  "gradient_clipping": 1.0,
  "zero_optimization": {
    "stage": 2,
    "offload_optimizer": {
      "device": "cpu",
      "pin_memory": true
    },
    "contiguous_gradients": true,
    "overlap_comm": false,
    "reduce_bucket_size": 20000000.0,
    "allgather_bucket_size": 20000000.0
  },
  "optimizer": {
    "type": "AdamW",
    "params": {
      "lr": 0.0002,
      "betas": [
        0.9,
        0.999
      ],
      "eps": 1e-08,
      "weight_decay": 0.0
    }
  },
  "scheduler": {
    "type": "WarmupDecayLR",
    "params": {
      "total_num_steps": "auto",
      "warmup_min_lr": 0,
      "warmup_max_lr": 0.0002,
      "warmup_num_steps": 375
    }
  },
  "zero_force_ds_cpu_optimizer": false,
  "bf16": {
    "enabled": true
  },
  "fp16": {
    "enabled": false
  },
  "steps_per_print": 2000,
  "wall_clock_breakdown": false
}